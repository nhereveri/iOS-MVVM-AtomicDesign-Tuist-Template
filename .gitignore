# ============================================================
# Tuist — Generated files
# ============================================================
# These are fully regenerated by `tuist generate`.
# Never commit them; every developer runs `tuist generate` after cloning.

*.xcodeproj
*.xcworkspace

# Tuist binary and internal cache
.tuist-bin/
.tuist/

# Tuist dependencies cache (resolved by `tuist install`)
Tuist/.build/
Tuist/Dependencies/

# ============================================================
# Xcode — Build artifacts and user data
# ============================================================

DerivedData/
build/
*.ipa
*.xcarchive
*.dSYM.zip
*.dSYM

# Xcode per-user settings (schemes, breakpoints, etc.)
xcuserdata/
*.xcuserstate
*.xccheckout
*.moved-aside

# Xcode Previews cache
__Previews/

# ============================================================
# Swift Package Manager
# ============================================================
# .build/ is SPM's local build folder when running `swift build` directly.
# Package.resolved IS committed so all developers use identical dependency versions.

.build/
*.resolved~

# ============================================================
# macOS
# ============================================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
Thumbs.db

# ============================================================
# Fastlane (if added later)
# ============================================================

fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/

# ============================================================
# Environment and secrets
# ============================================================
# Never commit API keys, tokens, or provisioning profiles.

.env
.env.local
.env.*.local
*.p12
*.mobileprovision
AuthKey_*.p8
ExportOptions.plist

# ============================================================
# Tools
# ============================================================

# Mint package manager lockfile (if used)
# Mintfile is committed; its resolved cache is not
.mint/

# Simulator logs
~/Library/Logs/DiagnosticReports/

# Instruments traces
*.trace
